@model List<TodoApp.Models.TaskItem>
@{ ViewData["Title"] = "My Tasks"; }
<h2>My Tasks</h2>
<form asp-action="Index" method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <input name="searchTitle" value="@ViewBag.SearchTitle" class="form-control" placeholder="Search by title" />
    </div>
    <div class="col-auto"><button class="btn btn-secondary">Search</button></div>
    <div class="col-auto"><a asp-action="Add" class="btn btn-primary">Add Task</a></div>
</form>
<table class="table table-striped">
    <thead><tr><th>Title</th><th>Status</th><th></th></tr></thead>
    <tbody>
    @foreach (var t in Model)
    {
        <tr>
            <td>@t.Title</td>
            <td>@(t.IsDone ? "Done" : "Pending")</td>
            <td>
                <a asp-action="Toggle" asp-route-id="@t.TaskId" class="btn btn-sm btn-outline-success">Toggle</a>
                <a asp-action="Delete" asp-route-id="@t.TaskId" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
@if (Model.Count == 0)
{
    <p>No tasks found.</p>
}
